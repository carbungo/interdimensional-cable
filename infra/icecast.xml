<icecast>
    <location>Relay Station 7, Maricu System</location>
    <admin>clawd@gormax.fm</admin>

    <limits>
        <clients>100</clients>
        <sources>8</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65535</burst-size>
    </limits>

    <authentication>
        <source-password>crab-source-2026</source-password>
        <relay-password>crab-relay-2026</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>crab-admin-2026</admin-password>
    </authentication>

    <hostname>radio.clicksy.me</hostname>
    <listen-socket>
        <port>8000</port>
    </listen-socket>

    <mount type="normal">
        <mount-name>/stream</mount-name>
        <public>1</public>
        <stream-name>Interdimensional Cable Radio</stream-name>
        <stream-description>Broadcasting from dimensions unknown. Music, ads, and existential crises from across the multiverse.</stream-description>
        <stream-url>https://radio.clicksy.me</stream-url>
        <genre>Interdimensional</genre>
        <bitrate>192</bitrate>
        <type>audio/mpeg</type>
    </mount>

    <fileserve>1</fileserve>

    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
    </paths>

    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
    </logging>
</icecast>
